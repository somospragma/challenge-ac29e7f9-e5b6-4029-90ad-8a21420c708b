# Training and Evaluation Notebook
import tensorflow as tf
from sklearn.model_selection import train_test_split
from sklearn.metrics import mean_squared_error
import pandas as pd

# Load cleaned data
data = pd.read_csv('data/cleaned_data.csv')

# Split data into training and testing sets
train_data, test_data = train_test_split(data, test_size=0.2, random_state=42)

# Prepare data for training
# Example: normalize data, reshape for LSTM input, etc.
train_data_normalized = (train_data - train_data.min()) / (train_data.max() - train_data.min())
test_data_normalized = (test_data - test_data.min()) / (test_data.max() - test_data.min())

# Build and compile the model
input_shape = (train_data_normalized.shape[1], 1)
model = build_rnn_attention_model(input_shape)
model.compile(optimizer='adam', loss='mean_squared_error')

# Train the model
model.fit(train_data_normalized, epochs=10, batch_size=32, validation_split=0.2)

# Evaluate the model
predictions = model.predict(test_data_normalized)
mse = mean_squared_error(test_data, predictions)
print(f'Mean Squared Error: {mse}')

# Save evaluation results
results = pd.DataFrame({'Actual': test_data, 'Predicted': predictions})
results.to_csv('results/evaluation_results.csv', index=False)